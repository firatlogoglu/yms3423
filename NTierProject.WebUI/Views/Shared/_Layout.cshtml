<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="">
    <meta name="author" content="Mosaddek">
    <meta name="keyword" content="FlatLab, Dashboard, Bootstrap, Admin, Template, Theme, Responsive, Fluid, Retina">
    <link rel="shortcut icon" href="~/Content/adminTheme/img/favicon.png">
    <title>Horizontal Menu</title>
    <!-- Bootstrap core CSS -->
    <link href="~/Content/adminTheme/css/bootstrap.min.css" rel="stylesheet">
    <link href="~/Content/adminTheme/css/bootstrap-reset.css" rel="stylesheet">
    <!--external css-->
    <link href="~/Content/adminTheme/assets/font-awesome/css/font-awesome.css" rel="stylesheet" />
    <!--<link href="~/Content/adminTheme/css/navbar-fixed-top.css" rel="stylesheet">-->
    <!-- Custom styles for this template -->
    <link href="~/Content/adminTheme/css/style.css" rel="stylesheet">
    <link href="~/Content/adminTheme/css/style-responsive.css" rel="stylesheet" />
    <link href="~/Content/adminTheme/assets/bootstrap-fileupload/bootstrap-fileupload.css" rel="stylesheet" />
    <!-- HTML5 shim and Respond.js IE8 support of HTML5 tooltipss and media queries -->
    <!--[if lt IE 9]>
      <script src="~/Content/adminTheme/js/html5shiv.js"></script>
      <script src="~/Content/adminTheme/js/respond.min.js"></script>
    <![endif]-->
   

</head>
<body class="full-width">
    <section id="container" class="">
        <!--header start-->
        <header class="header white-bg">
            <div class="sidebar-toggle-box">
                <div data-original-title="Toggle Navigation" data-placement="right" class="icon-reorder tooltips"></div>
            </div>
            <div class="navbar-header" style="float:none; z-index:-9999">
                <button type="button" class="navbar-toggle" data-toggle="collapse" data-target=".navbar-collapse">
                    <span class="icon-bar"></span>
                    <span class="icon-bar"></span>
                    <span class="icon-bar"></span>
                </button>
                <!--logo start-->
                <a href="~/Content/adminTheme/index.html" class="logo">E.<span>Ticaret</span></a>
                <!--logo end-->
                <div class="horizontal-menu navbar-collapse collapse ">
                    <ul class="nav navbar-nav">
                        <li><a href="@Url.Action("Index", "Home")">Anasayfa</a></li>
                        <li><a href="@Url.Action("Index", "Product")">Ürünler</a></li>
                        <li class="dropdown">
                            <a data-toggle="dropdown" data-hover="dropdown" class="dropdown-toggle" href="~/Content/adminTheme/#">Kategori<b class=" icon-angle-down"></b></a>
                            <ul class="dropdown-menu">
                                <li><a href="~/Content/adminTheme/general.html">Elbise</a></li>
                                <li><a href="~/Content/adminTheme/buttons.html">Kişisel Bakım</a></li>
                                <li><a href="~/Content/adminTheme/widget.html">Pantalon</a></li>
                                <li><a href="~/Content/adminTheme/slider.html">Elektronik</a></li>
                                <li><a href="~/Content/adminTheme/nestable.html">Spor Giyim</a></li>

                            </ul>
                        </li>


                    </ul>
                </div>
                <div class="top-nav ">
                    <ul class="nav pull-right top-menu">
                        <li>
                            <input type="text" class="form-control search" placeholder=" Search">
                        </li>
                        <!-- user login dropdown start-->
                        <!-- user login dropdown end -->
                    </ul>
                </div>
            </div>
        </header>
        <!--header end-->
        <!--sidebar start-->
        <aside>
            <div id="sidebar" class="nav-collapse">
                <!-- sidebar menu start-->
                <ul class="sidebar-menu" id="nav-accordion">
                    <li>
                        <a href="@Url.Action("Index", "Home")">
                            <i class="icon-dashboard"></i>
                            <span>Anasayfa</span>
                        </a>
                    </li>
                    <li>
                        <a href="@Url.Action("Index", "Product")">
                            <i class="icon-dashboard"></i>
                            <span>Ürünler</span>
                        </a>
                    </li>
                    <li class="sub-menu dcjq-parent-li">
                        <a href="@Url.Action("Index","Category")" class="active dcjq-parent">
                            <i class="icon-shopping-cart"></i>
                            <span>Kategori</span>
                            <span class="dcjq-icon"></span>
                        </a>
                        <ul class="sub" style="display: block;">
                            <li><a href="@Url.Action("Index","Category")">Elbise</a></li>
                            <li><a href="@Url.Action("Index","Category")">Kişisel Bakım</a></li>
                            <li><a href="@Url.Action("Index","Category")">Pantalon</a></li>
                            <li><a href="@Url.Action("Index","Category")">Elektronik</a></li>
                            <li><a href="@Url.Action("Index","Category")">Spor Giyim</a></li>

                        </ul>
                    </li>


                    <li>
                        <a href="login.html">
                            <i class="icon-user"></i>
                            <span>Login Page</span>
                        </a>
                    </li>

                </ul>
                <!-- sidebar menu end-->
            </div>
        </aside>
        <!--sidebar end-->
        <!--main content start-->
        <section id="main-content">
            <section class="wrapper">
                @RenderBody()
            </section>
        </section>
        <!--main content end-->
        <!--footer start-->
        <footer class="site-footer">
            <div class="text-center">
                2013 &copy; FlatLab by VectorLab.
                <a href="~/Content/adminTheme/#" class="go-top">
                    <i class="icon-angle-up"></i>
                </a>
            </div>
        </footer>
        <!--footer end-->
    </section>
    <!-- js placed at the end of the document so the pages load faster -->
    <script src="~/Content/adminTheme/js/jquery.js"></script>
    <script src="~/Content/adminTheme/js/bootstrap.min.js"></script>
    <script class="include" type="text/javascript" src="~/Content/adminTheme/js/jquery.dcjqaccordion.2.7.js"></script>
    <script type="text/javascript" src="~/Content/adminTheme/js/hover-dropdown.js"></script>
    <script src="~/Content/adminTheme/js/jquery.scrollTo.min.js"></script>
    <script src="~/Content/adminTheme/js/jquery.nicescroll.js" type="text/javascript"></script>
    <script src="~/Content/adminTheme/js/respond.min.js"></script>
    <!--common script for all pages-->
    <script src="~/Content/adminTheme/js/common-scripts.js"></script>
    @RenderSection("scripts",false)
</body>
</html>
